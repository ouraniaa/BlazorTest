@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">BlazorTest</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        
        @* 1. ΑΡΧΙΚΗ ΣΕΛΙΔΑ: Ορατή σε όλους *@
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="personal-info">
                        <span class="bi bi-person-badge-fill" aria-hidden="true"></span> Personal Information
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="todo">
                        <span class="bi bi-calendar-check-fill" aria-hidden="true"></span> My Planner
                    </NavLink>
                </div>

                @* Manager Link *@
                <AuthorizeView Roles="Manager" Context="managerContext">
                    @{
                        var companyId = managerContext.User.FindFirst("CompanyId")?.Value;
                    }
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"/my-employees/{companyId}")">
                            <span class="bi bi-building-gear" aria-hidden="true"></span> My Company
                        </NavLink>
                    </div>
                </AuthorizeView>

                @* Admin Links *@
                <AuthorizeView Roles="Admin" Context="adminContext">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="user-management">
                            <span class="bi bi-people-fill" aria-hidden="true"></span> User Management
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="company-management">
                            <span class="bi bi-buildings-fill" aria-hidden="true"></span> Companies
                        </NavLink>
                    </div>
                </AuthorizeView>
            </Authorized>
        </AuthorizeView>

        @* 3. FOOTER: Login/Sign Up (για Guests) ή Logout (για συνδεδεμένους) *@
        <div class="nav-footer px-3 py-3 mt-auto">
            <div class="d-grid gap-2">
                <AuthorizeView>
                    <Authorized>
                        @* Εμφανίζεται μόνο όταν είσαι συνδεδεμένος *@
                        <a class="nav-link btn btn-outline-danger text-start border-0" href="auth/logout">
                            <span class="bi bi-box-arrow-left" aria-hidden="true"></span> Logout
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        @* Εμφανίζονται μόνο όταν έχεις κάνει Logout *@
                        <NavLink class="nav-link btn btn-outline-light text-start" href="login">
                            <span class="bi bi-lock-fill" aria-hidden="true"></span> Login
                        </NavLink>
                        <NavLink class="nav-link btn btn-outline-info text-start" href="signup">
                            <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Sign Up
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </nav>
</div>