@page "/admin"
@using Domain.Models
@using Application.Interfaces
@using Microsoft.AspNetCore.Components.QuickGrid
@inject IUserService UserService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Admin Dashboard</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>User Management</h2>
        <button class="btn btn-success" @onclick="() => NavManager.NavigateTo("/signup")">
            <i class="bi bi-plus-lg"></i> Add New User
        </button>
    </div>

    @if (users == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p>Fetching users...</p>
        </div>
    }
    else if (!users.Any())
    {
        <div class="alert alert-info">No users found in the database.</div>
    }
    else
    {
        <div class="card shadow">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>AFM</th>
                            <th>Phone</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr>
                                <td>@user.Name @user.LastName</td>
                                <td>@user.Email</td>
                                <td>@user.AFM</td>
                                <td>@user.PhoneNumber</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditUser(user.Id)">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(user.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<User>? users;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        try
        {
            users = await UserService.GetAllUsers();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading users: {ex.Message}");
        }
    }

    private void EditUser(int id)
    {
        NavManager.NavigateTo($"/admin/edit-user/{id}");
    }

    private async Task DeleteUser(int id)
    {
        if (true) 
        {
            await UserService.DeleteById(id);
            await LoadUsers();
        }
    }
}