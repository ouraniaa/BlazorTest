@page "/users/edit"
@using Application.Interfaces
@using Microsoft.EntityFrameworkCore
@using Domain.Models
@inject IUserService UserService
@using Application.Utilities
@inject ICompanyService CompanyService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>User</h2>
<hr />
@if (User is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div class="col-md-4">
            <EditForm method="post" Model="User" OnValidSubmit="UpdateUser" FormName="edit" Enhance>
                <DataAnnotationsValidator />
                <ValidationSummary role="alert"/>
                <input type="hidden" name="User.Id" value="@User.Id" />
                <div class="mb-3">
                    <label for="name" class="form-label">Name:</label>
                    <InputText id="name" @bind-Value="User.Name" class="form-control" />
                    <ValidationMessage For="() => User.Name" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="lastname" class="form-label">LastName:</label>
                    <InputText id="lastname" @bind-Value="User.LastName" class="form-control" />
                    <ValidationMessage For="() => User.LastName" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label for="phonenumber" class="form-label">PhoneNumber:</label>
                    <InputText id="phonenumber" @bind-Value="User.PhoneNumber" class="form-control" />
                    <ValidationMessage For="() => User.PhoneNumber" class="text-danger" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Email:</label>
                    <InputText Value="@User.Email"
                               ValueChanged="@((string value) => OnEmailChanged(value))"
                               ValueExpression="@(() => User.Email)"
                               class="form-control" />
    
                    @if (emailError != null)
                    {
                        <div class="text-danger">@emailError</div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label">AFM:</label>
                    <InputText Value="@User.AFM"
                               ValueChanged="@((string value) => OnAFMChanged(value))"
                               ValueExpression="@(() => User.AFM)"
                               class="form-control" />
    
                    @if (afmError != null)
                    {
                        <div class="text-danger">@afmError</div>
                    }
                </div>
                <div class="mb-3">
                    <label for="company" class="form-label">Company:</label>
                   
                    <InputSelect id="company" @bind-Value="User.CompanyId" class="form-select">
                        <option value="0">-- Select a Company --</option>
                        @foreach (var company in CompaniesList)
                        {
                            <option value="@company.Id">@company.Name</option>
                        }
                    </InputSelect>
                    <div class="card mt-4 mb-4 shadow-sm">
                        <div class="card-header bg-light">
                            <strong>Manage Nicknames</strong>
                        </div>
                        <div class="card-body">
                            <div class="input-group mb-3">
                                <input type="text" @bind="newNickname" class="form-control" placeholder="Type a nickname..." />
                                <button class="btn btn-outline-secondary" type="button" @onclick="AddNicknameToList">Add</button>
                            </div>

                            <ul class="list-group">
                                @for (int i = 0; i < NicknameStrings.Count; i++)
                                {
                                    var index = i; 
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        @if (editingIndex == index)
                                        {
                                            <input type="text" class="form-control form-control-sm me-2"
                                                   @bind="tempEditValue" @onkeyup="@(e => HandleKeyUp(e, index))" autofocus />
                
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm btn-success" @onclick="() => SaveEdit(index)">Save</button>
                                                <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelEdit">Cancel</button>
                                            </div>
                                        }
                                        else
                                        {
                                            <span>@NicknameStrings[index]</span>
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(index)">Edit</button>
                                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveNickname(NicknameStrings[index])">Remove</button>
                                            </div>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                    <ValidationMessage For="() => User.CompanyId" class="text-danger" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/users">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int Id { get; set; }

    [SupplyParameterFromForm]
    private User? User { get; set; }

    private List<Company> CompaniesList = new();
    private string? afmError; 
    private string? emailError;
    private string? newNickname;
    private List<string> NicknameStrings = new();
    
    private string? serverError;


    protected override async Task OnInitializedAsync()
    {
        CompaniesList = await CompanyService.GetAllCompanies();

        User = await UserService.GetUserByID(Id);
        
        if (User is null)
        {
            NavigationManager.NavigateTo("/user-management");
            return;
        }

        if (User.Nicknames != null)
        {
            NicknameStrings = User.Nicknames.Select(n => n.Value).ToList();
        }
    }
    
    private void AddNicknameToList()
    {
        if (!string.IsNullOrWhiteSpace(newNickname) && !NicknameStrings.Contains(newNickname.Trim()))
        {
            NicknameStrings.Add(newNickname.Trim());
            newNickname = string.Empty;
        }
    }

    private void RemoveNickname(string nick)
    {
        NicknameStrings.Remove(nick);
    }


    private async Task UpdateUser()
    {
        serverError = null;
        
        // Validation
        afmError = AFMValidator.ValidateVatNumber(User.AFM);
        emailError = EmailValidator.ValidateEmail(User.Email);

        if (afmError != null || emailError != null)
        {
            serverError = afmError ?? emailError;
            return;
        }

        try
        {
            User.Nicknames = NicknameStrings.Select(name => new Nickname
            {
                Value = name,
                UserId = User.Id
            }).ToList();

            await UserService.Update(User);
            NavigationManager.NavigateTo("/user-management");
        }
        catch (Exception ex)
        {
            serverError = "Σφάλμα κατά την ενημέρωση: " + ex.Message;
        }
    }

    private void OnEmailChanged(string value)
    {
        User.Email = value;
        emailError = EmailValidator.ValidateEmail(value);
    }

    private void OnAFMChanged(string value)
    {
        User.AFM = value;
        afmError = AFMValidator.ValidateVatNumber(value);
    }

    private int? editingIndex = null; 
    private string tempEditValue = ""; 

    private void StartEdit(int index)
    {
        editingIndex = index;
        tempEditValue = NicknameStrings[index]; 
    }

    private void SaveEdit(int index)
    {
        if (!string.IsNullOrWhiteSpace(tempEditValue))
        {
            NicknameStrings[index] = tempEditValue.Trim();
        }
        CancelEdit();
    }

    private void CancelEdit()
    {
        editingIndex = null;
        tempEditValue = "";
    }

    private void HandleKeyUp(KeyboardEventArgs e, int index)
    {
        if (e.Key == "Enter") SaveEdit(index);
        if (e.Key == "Escape") CancelEdit();
    }
    private void Cancel() => NavigationManager.NavigateTo("/user-management");
}
