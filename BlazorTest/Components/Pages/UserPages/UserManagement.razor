@page "/user-management"
@using Domain.Models
@using Application.Interfaces
@using Microsoft.AspNetCore.Components.QuickGrid
@inject IUserService UserService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>User Management</PageTitle>

<div class="container-fluid mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill text-primary me-2"></i>User Management
            </h2>
            <p class="text-muted">Manage all members of the program.</p>
        </div>
        <button class="btn btn-primary btn-lg rounded-3 shadow-sm" @onclick="GoToCreate">
            <i class="bi bi-person-plus-fill me-2"></i>Add User
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-person-check text-primary fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Total Users</h6>
                        <h4 class="fw-bold mb-0">@(users?.Count ?? 0)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            @if (users == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Loading list of users...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <QuickGrid Class="table table-hover align-middle mb-0" Items="FilteredUsers" Pagination="pagination">
                        
                        <TemplateColumn Title="User" Sortable="true" Class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                    <i class="bi bi-person text-secondary"></i>
                                </div>
                                <div>
                                    <div class="fw-bold">@context.Name @context.LastName</div>
                                    <div class="text-muted small">@context.Email</div>
                                </div>
                            </div>
                        </TemplateColumn>

                        <PropertyColumn Property="u => u.AFM" Title="AFM" Class="text-muted" />
                        
                        <TemplateColumn Title="Phone Number">
                            <i class="bi bi-telephone me-1 text-muted small"></i> @context.PhoneNumber
                        </TemplateColumn>

                        <TemplateColumn Title="Nicknames">
                            @if (context.Nicknames != null && context.Nicknames.Any())
                            {
                                @foreach (var nick in context.Nicknames)
                                {
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 rounded-pill me-1">
                                        @nick.Value
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small italic">None</span>
                            }
                        </TemplateColumn>

                        <TemplateColumn Title="Actions" Class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm action-btn"
                                        title="Επεξεργασία"
                                        @onclick="() => GoToEdit(context.Id)">
                                    <i class="bi bi-pencil-fill me-1"></i> Edit
                                </button>

                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm action-btn"
                                        title="Διαγραφή"
                                        @onclick="() => GoToDelete(context.Id)">
                                    <i class="bi bi-trash3-fill me-1"></i> Delete
                                </button>
                            </div>
                        </TemplateColumn>

                    </QuickGrid>
                </div>

                <div class="p-3 border-top d-flex justify-content-center">
                    <Paginator State="@pagination" />
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<User>? users;
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    
    private IQueryable<User> FilteredUsers => (users ?? new()).AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        users = await UserService.GetAllUsers();
    }

    private void GoToCreate() => NavigationManager.NavigateTo("/users/create");
    private void GoToEdit(int id) => NavigationManager.NavigateTo($"/users/edit?id={id}");
    
    private async Task GoToDelete(int id)
    {
        await HandleDelete(id);
    }

    private async Task HandleDelete(int id)
    {
        try
        {
            await UserService.DeleteById(id);
            users = await UserService.GetAllUsers();
        }
        catch (Exception ex)
        {
        }
    }
}