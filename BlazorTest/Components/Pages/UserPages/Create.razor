@page "/users/create"
@using Domain.Models
@using Application.Interfaces
@using Application.Utilities
@inject IUserService UserService
@inject ICompanyService CompanyService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Create User</PageTitle>

<h1>Create</h1>
<h2>User</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <EditForm Model="User" OnValidSubmit="AddUser">
            <DataAnnotationsValidator />
            
            @if (serverError != null)
            {
                <div class="alert alert-danger">@serverError</div>
            }

            <div class="mb-3">
                <label for="name" class="form-label">Name:</label>
                <InputText id="name" @bind-Value="User.Name" class="form-control" />
                <ValidationMessage For="() => User.Name" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="lastname" class="form-label">LastName:</label>
                <InputText id="lastname" @bind-Value="User.LastName" class="form-control" />
                <ValidationMessage For="() => User.LastName" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <InputText id="email" @bind-Value="User.Email" class="form-control" />
                <ValidationMessage For="() => User.Email" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="afm" class="form-label">AFM:</label>
                <InputText id="afm" @bind-Value="User.AFM" class="form-control" />
                <ValidationMessage For="() => User.AFM" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="phone" class="form-label">Phone Number:</label>
                <InputText id="phone" @bind-Value="User.PhoneNumber" class="form-control" />
                <ValidationMessage For="() => User.PhoneNumber" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password:</label>
                <InputText id="password" type="password" @bind-Value="User.Password" class="form-control" />
                <ValidationMessage For="() => User.Password" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="company" class="form-label">Company:</label>
                <InputSelect id="company" @bind-Value="User.CompanyId" class="form-select">
                    <option value="0">-- Select a Company --</option>
                    @foreach (var company in CompaniesList)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => User.CompanyId" class="text-danger" />
            </div>

            <div class="card mt-4 mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <strong>Add Nicknames</strong>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" @bind="newNickname" class="form-control" placeholder="Type a nickname..." />
                        <button class="btn btn-outline-secondary" type="button" @onclick="AddNicknameToList">Add</button>
                    </div>

                    <ul class="list-group">
                        @foreach (var nick in NicknameStrings)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@nick</span>
                                <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveNickname(nick)">Remove</button>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Create User</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private User User { get; set; } = new();
    private List<Company> CompaniesList = new();
    private string? newNickname;
    private List<string> NicknameStrings = new();
    private string? serverError;

    protected override async Task OnInitializedAsync()
    {
        CompaniesList = await CompanyService.GetAllCompanies();
    }

    private void AddNicknameToList()
    {
        if (!string.IsNullOrWhiteSpace(newNickname) && !NicknameStrings.Contains(newNickname.Trim()))
        {
            NicknameStrings.Add(newNickname.Trim());
            newNickname = string.Empty;
        }
    }

    private void RemoveNickname(string nick)
    {
        NicknameStrings.Remove(nick);
    }



    private async Task AddUser()
    {
        serverError = null;
        string afmResult = AFMValidator.ValidateVatNumber(User.AFM);
        if (afmResult != null)
        {
            serverError = afmResult;
            return;
        }

        try
        {
            User.Nicknames = NicknameStrings.Select(name => new Nickname
            {
                Value = name
            }).ToList();

            await UserService.Save(User);
            NavigationManager.NavigateTo("/user-management");
        }
        catch (Exception ex)
        {
            serverError = "Παρουσιάστηκε σφάλμα κατά την αποθήκευση: " + ex.Message;
        }
    }

    private void Cancel() => NavigationManager.NavigateTo("/user-management");
}