@page "/my-employees/{LoggedInCompanyId:int}"
@attribute [Authorize(Roles = "Admin, Manager")]
@using Domain.Models
@using Application.Interfaces
@using Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.AspNetCore.Authorization
@inject ICompanyService CompanyService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Προσωπικό Εταιρείας</PageTitle>

<div class="container-fluid mt-4 pb-5">
    @if (currentCompany == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted">Φόρτωση στοιχείων εταιρείας...</p>
        </div>
    }
    else
    {
        @* Header Section *@
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="company-management" class="text-decoration-none">Εταιρείες</a></li>
                        <li class="breadcrumb-item active">@currentCompany.Name</li>
                    </ol>
                </nav>
                <h2 class="fw-bold text-dark mb-0">
                    <i class="bi bi-people-fill text-primary me-2"></i>Λίστα Υπαλλήλων
                </h2>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary rounded-3 shadow-sm" @onclick='() => Nav.NavigateTo("/company-management")'>
                    <i class="bi bi-arrow-left me-1"></i> Επιστροφή
                </button>
                <button class="btn btn-primary rounded-3 shadow-sm" @onclick='() => Nav.NavigateTo("/users/create")'>
                    <i class="bi bi-person-plus-fill me-1"></i> Προσθήκη Υπαλλήλου
                </button>
            </div>
        </div>

        @* Company Banner *@
        <div class="alert alert-white border shadow-sm rounded-3 d-flex align-items-center mb-4 p-3">
            <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                <i class="bi bi-building text-primary fs-4"></i>
            </div>
            <div>
                <div class="text-muted small">Διαχείριση Προσωπικού για:</div>
                <h5 class="fw-bold mb-0">@currentCompany.Name</h5>
            </div>
            <div class="ms-auto pe-3">
                <span class="badge bg-secondary rounded-pill">Σύνολο: @employees.Count</span>
            </div>
        </div>

        @* QuickGrid Card *@
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <QuickGrid Class="table table-hover align-middle mb-0" Items="employees.AsQueryable()" Pagination="pagination">
                        
                        <TemplateColumn Title="Υπάλληλος" Sortable="true" Class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                    <span class="fw-bold text-primary">@context.Name[0]</span>
                                </div>
                                <div>
                                    <div class="fw-bold">@context.Name @context.LastName</div>
                                    <div class="text-muted small">@context.Email</div>
                                </div>
                            </div>
                        </TemplateColumn>

                        <PropertyColumn Property="u => u.AFM" Title="ΑΦΜ" Class="text-muted" />

                        <TemplateColumn Title="Επικοινωνία">
                            <div class="d-flex flex-column small">
                                <span><i class="bi bi-telephone me-1 text-muted"></i> @context.PhoneNumber</span>
                            </div>
                        </TemplateColumn>

                        <TemplateColumn Title="Ενέργειες" Class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3 action-btn" 
                                        @onclick="() => EditEmployee(context)">
                                    <i class="bi bi-pencil-fill me-1"></i> Edit
                                </button>
                                @* Προαιρετικά: Εδώ ο Admin μπορεί να βλέπει και Delete, ο Manager ίσως όχι *@
                                <AuthorizeView Roles="Admin">
                                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3 action-btn" 
                                            @onclick="() => HandleDelete(context.Id)">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </AuthorizeView>
                            </div>
                        </TemplateColumn>

                    </QuickGrid>
                </div>
                
                <div class="p-3 border-top d-flex justify-content-center">
                    <Paginator State="@pagination" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int LoggedInCompanyId { get; set; }

    private Company? currentCompany;
    private List<User> employees = new();
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            currentCompany = await CompanyService.GetCompanyById(LoggedInCompanyId);
            if (currentCompany != null)
            {
                await LoadEmployees();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }

    private async Task LoadEmployees()
    {
        employees = await CompanyService.GetEmployeesByCompanyId(LoggedInCompanyId);
    }

    private void EditEmployee(User user)
    {
        Nav.NavigateTo($"/users/edit?id={user.Id}");
    }

    private async Task HandleDelete(int id)
    {
        // Εδώ καλείς το Service διαγραφής αν χρειάζεται
        await LoadEmployees();
    }
}