@page "/company-management"
@attribute [Authorize(Roles = "Admin")]
@using Domain.Models
@using Application.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.QuickGrid
@inject ICompanyService CompanyService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Company Management</PageTitle>

<div class="container-fluid mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-buildings-fill text-primary me-2"></i>Company Management
            </h2>
            <p class="text-muted">Manage all registered organizations in the system.</p>
        </div>
        <button class="btn btn-primary btn-lg rounded-3 shadow-sm" @onclick="OpenCreateModal">
            <i class="bi bi-plus-circle-fill me-2"></i>Add Company
        </button>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
                        <i class="bi bi-building-check text-primary fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Total Companies</h6>
                        <h4 class="fw-bold mb-0">@(companies?.Count ?? 0)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-0">
            @if (companies == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Loading companies...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <QuickGrid Class="table table-hover align-middle mb-0" Items="companies.AsQueryable()" Pagination="pagination">
                        
                        <TemplateColumn Title="Company Name" Sortable="true" Class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-3 d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                    <i class="bi bi-building text-secondary fs-5"></i>
                                </div>
                                <div class="fw-bold text-primary">@context.Name</div>
                            </div>
                        </TemplateColumn>

                        <TemplateColumn Title="Address">
                            <i class="bi bi-geo-alt me-1 text-muted small"></i> @context.Address
                        </TemplateColumn>

                        <TemplateColumn Title="Employees" Class="text-center">
                            <button class="btn btn-sm btn-light rounded-pill px-3 border" @onclick="() => ManageEmployees(context.Id)">
                                <i class="bi bi-people me-1"></i> View List
                            </button>
                        </TemplateColumn>

                        <TemplateColumn Title="Actions" Class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm action-btn"
                                        @onclick="() => OpenEditModal(context)">
                                    <i class="bi bi-pencil-fill me-1"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm action-btn"
                                        @onclick="() => HandleDelete(context.Id)">
                                    <i class="bi bi-trash3-fill me-1"></i> Delete
                                </button>
                            </div>
                        </TemplateColumn>

                    </QuickGrid>
                </div>

                <div class="p-3 border-top d-flex justify-content-center">
                    <Paginator State="@pagination" />
                </div>
            }
        </div>
    </div>
</div>

<CompanyModal IsVisible="isModalVisible"
              CurrentCompany="selectedCompany"
              OnSave="RefreshData"
              OnClose="HideModal" />

@code {
    private List<Company> companies = new();
    private bool isModalVisible = false;
    private Company selectedCompany = new();
    PaginationState pagination = new PaginationState { ItemsPerPage = 10 };

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        companies = await CompanyService.GetAllCompanies();
        isModalVisible = false;
    }

    private void OpenCreateModal()
    {
        selectedCompany = new Company();
        isModalVisible = true;
    }

    private void OpenEditModal(Company company)
    {
        selectedCompany = company;
        isModalVisible = true;
    }

    private void HideModal() => isModalVisible = false;

    private void ManageEmployees(int id) => NavigationManager.NavigateTo($"/my-employees/{id}");

    private async Task HandleDelete(int id)
    {
        try
        {
            await CompanyService.DeleteById(id);
            await RefreshData();
        }
        catch (Exception) { }
    }
}