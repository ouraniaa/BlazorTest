@using Domain.Models
@using Application.Interfaces
@inject IToDoService ToDoService

<div class="card h-100 border-0 shadow-sm rounded-4 hover-shadow transition">
    <div class="card-header bg-primary text-white border-0 py-3 rounded-top-4 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-bold">@ToDoList.Name</h5>
        <div class="d-flex align-items-center gap-2">
            @if (ToDoList.Tasks != null)
            {
                <span class="badge bg-white text-primary rounded-pill">
                    @ToDoList.Tasks.Count(t => t.IsCompleted)/@ToDoList.Tasks.Count
                </span>
            }
            <button class="btn btn-sm text-white-50 p-0 border-0" @onclick="DeleteList" title="Delete List">
                <i class="bi bi-trash3-fill"></i>
            </button>
        </div>
    </div>

    <div class="card-body py-3">
        <div class="task-container" style="max-height: 300px; overflow-y: auto;">
            @if (ToDoList.Tasks == null || !ToDoList.Tasks.Any())
            {
                <div class="text-center py-4">
                    <i class="bi bi-journal-text text-muted fs-4"></i>
                    <p class="text-muted small mt-2 italic">No tasks yet.</p>
                </div>
            }
            else
            {
                @foreach (var task in ToDoList.Tasks)
                {
                    <TaskItem Task="task" OnChanged="HandleUpdate" />
                }
            }
        </div>
    </div>

    <div class="card-footer bg-transparent border-0 pb-3">
        <div class="input-group input-group-sm rounded-pill border bg-light p-1">
            <input type="text" class="form-control border-0 bg-transparent ps-3 shadow-none"
                   placeholder="Νέα εργασία..."
                   @bind="newTaskDesc"
                   @onkeyup="HandleKeyUp" />
            <button class="btn btn-primary rounded-circle p-0 d-flex align-items-center justify-content-center"
                    style="width: 28px; height: 28px;"
                    @onclick="AddNewTask">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public ToDoList ToDoList { get; set; } = default!;
    [Parameter] public EventCallback OnListChanged { get; set; }
    
    private string newTaskDesc = "";

    private async Task AddNewTask()
    {
        if (string.IsNullOrWhiteSpace(newTaskDesc)) return;

        await ToDoService.AddTaskToListAsync(ToDoList.Id, newTaskDesc);
        
        newTaskDesc = "";
        await HandleUpdate();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddNewTask();
    }

    private async Task DeleteList()
    {
        await ToDoService.DeleteListAsync(ToDoList.Id);
        await HandleUpdate();
    }

    private async Task HandleUpdate()
    {
        await OnListChanged.InvokeAsync();
    }
}